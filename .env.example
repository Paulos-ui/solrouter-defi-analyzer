# ============================================================
# SolRouter Private DeFi Analyzer — Environment Configuration
# ============================================================

# Your SolRouter API key (from https://solrouter.com after wallet connect)
SOLROUTER_API_KEY=sk_solrouter_your_key_here

# Solana RPC endpoint — use devnet for testing
SOLANA_RPC_URL=https://api.devnet.solana.com

# Target wallet to analyze (any Solana devnet address)
# Leave blank to be prompted at runtime
TARGET_WALLET=

# Helius API key (optional — increases RPC rate limits dramatically)
# Get free key at https://helius.dev
HELIUS_API_KEY=

# Model to use for encrypted inference
# Options: gpt-oss-20b (default, encrypted), gpt-4o, claude-3.5-sonnet
SOLROUTER_MODEL=gpt-oss-20b
